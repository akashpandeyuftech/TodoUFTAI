# Neon PostgreSQL connection strings
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-min-32-chars-long-here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Upstash Redis (for rate limiting) — optional, rate limiting disabled if not set
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
